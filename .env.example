# QuickBooks Online OAuth 2.0 Credentials
# Get these from https://developer.intuit.com/app/developer/dashboard
QBO_CLIENT_ID=your_client_id_here
QBO_CLIENT_SECRET=your_client_secret_here
QBO_REDIRECT_URI=http://localhost:8080/callback
QBO_ENVIRONMENT=production

# These get filled in automatically after first auth
QBO_REALM_ID=
QBO_REFRESH_TOKEN=
